<?php phpinfo(); ?>
Options -MultiViews -Indexes
RewriteEngine On
RewriteBase /

# 1. Handle Home Page (Root)
DirectoryIndex home.html
RewriteCond %{THE_REQUEST} ^[A-Z]{3,}\ /home\.html\ HTTP/
RewriteRule ^home\.html$ / [R=301,L]

# 2. Force Remove .html from any URL
# If a user sees .html, redirect them to the clean version
RewriteCond %{THE_REQUEST} \s/+(.*?)\.html[\s?] [NC]
RewriteRule ^ /%1 [R=301,L]

# 3. Internally link clean URL to .html file
# This happens behind the scenes so the URL stays clean
RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_FILENAME} !-d
RewriteCond %{REQUEST_FILENAME}.html -f
RewriteRule ^(.+)$ $1.html [L]
